      "mode": "text",
      "title": "What Is a Feeling?",
      "body": "A feeling is your mind and body reacting to what is happening around you.",
      "image": null
    },
    {
      "id": "ls_u1_s2",
      "type": "teach",
      "mode": "text",
      "title": "Feelings Are Signals",
      "body": "Feelings help you understand what you need. They are messages, not problems.",
      "image": null
    },

